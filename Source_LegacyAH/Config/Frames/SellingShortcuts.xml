<Ui xmlns="http://www.blizzard.com/wow/ui/">
  <Frame
    name="AuctionatorConfigSellingShortcutsFrameTemplate"
    virtual="true">

    <Scripts>
      <OnLoad inherit="append">Mixin(self, AuctionatorConfigSellingShortcutsFrameMixin); self:OnLoad()</OnLoad>
      <OnShow>self:OnShow()</OnShow>
      <OnHide>self:Save()</OnHide>
    </Scripts>

    <Frames>
      <Frame inherits="AuctionatorConfigurationTitleFrame" parentKey="TitleArea">
        
          
          
        
      <Scripts><OnLoad inherit="append">self.titleText = AUCTIONATOR_L_CONFIG_SELLING_SHORTCUTS_CATEGORY; self.subTitleText = AUCTIONATOR_L_CONFIG_SELLING_SHORTCUTS_TEXT; </OnLoad></Scripts></Frame>
      <Frame inherits="AuctionatorDropDown" parentKey="BagSelectShortcut">
        
          
          
          
        
        <Anchors>
          <Anchor point="TOPLEFT" relativeKey="$parent.TitleArea" relativePoint="BOTTOMLEFT"/>
        </Anchors>
      <Scripts><OnLoad inherit="append">self.labelText = AUCTIONATOR_L_CONFIG_SELLING_BAG_SELECT_SHORTCUT; self.textString = "RIGHT_CLICK;ALT_LEFT_CLICK;ALT_RIGHT_CLICK;SHIFT_LEFT_CLICK;SHIFT_RIGHT_CLICK;DISABLED"; self.valuesString = "right click;alt left click;alt right click;shift left click;shift right click;none"; </OnLoad></Scripts></Frame>
      <Frame parentKey="PostShortcut" inherits="AuctionatorKeyBindingConfigTemplate">
        <Anchors>
          <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT" relativeKey="$parent.BagSelectShortcut"/>
        </Anchors>
        
          
          
          
        
      <Scripts><OnLoad inherit="append">self.labelText = AUCTIONATOR_L_CONFIG_SELLING_POST_SHORTCUT; self.tooltipText = AUCTIONATOR_L_CONFIG_SELLING_POST_SHORTCUT_TOOLTIP_TEXT; self.tooltipTitleText = AUCTIONATOR_L_CUSTOM_KEYBOARD_SHORTCUTS; </OnLoad></Scripts></Frame>
      <Frame parentKey="SkipShortcut" inherits="AuctionatorKeyBindingConfigTemplate">
        <Anchors>
          <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT" relativeKey="$parent.PostShortcut"/>
        </Anchors>
        
          
          
          
        
      <Scripts><OnLoad inherit="append">self.labelText = AUCTIONATOR_L_CONFIG_SELLING_SKIP_SHORTCUT; self.tooltipText = AUCTIONATOR_L_CONFIG_SELLING_POST_SHORTCUT_TOOLTIP_TEXT; self.tooltipTitleText = AUCTIONATOR_L_CUSTOM_KEYBOARD_SHORTCUTS; </OnLoad></Scripts></Frame>
      <Frame parentKey="PrevShortcut" inherits="AuctionatorKeyBindingConfigTemplate">
        <Anchors>
          <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT" relativeKey="$parent.SkipShortcut"/>
        </Anchors>
        
          
          
          
        
      <Scripts><OnLoad inherit="append">self.labelText = AUCTIONATOR_L_CONFIG_SELLING_PREV_SHORTCUT; self.tooltipText = AUCTIONATOR_L_CONFIG_SELLING_POST_SHORTCUT_TOOLTIP_TEXT; self.tooltipTitleText = AUCTIONATOR_L_CUSTOM_KEYBOARD_SHORTCUTS; </OnLoad></Scripts></Frame>
    </Frames>
  </Frame>
</Ui>
