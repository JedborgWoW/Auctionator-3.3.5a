<Ui xmlns="http://www.blizzard.com/wow/ui/">
  <Frame
    name="AuctionatorConfigBasicOptionsFrameTemplate"
    virtual="true">

    <Scripts>
      <OnLoad inherit="append">Mixin(self, AuctionatorConfigBasicOptionsFrameMixin); self:OnLoad()</OnLoad>
      <OnShow>self:OnShow()</OnShow>
      <OnHide>self:Save()</OnHide>
    </Scripts>

    <Frames>
      <Frame inherits="AuctionatorConfigurationTitleFrame" parentKey="TitleArea">
        
          
          
        
      <Scripts><OnLoad inherit="append">self.titleText = AUCTIONATOR_L_CONFIG_BASIC_OPTIONS_CATEGORY; self.subTitleText = AUCTIONATOR_L_CONFIG_BASIC_OPTIONS_TEXT; </OnLoad></Scripts></Frame>

      <Frame inherits="AuctionatorConfigurationHeadingFrame" parentKey="DefaultTabHeading">
        
          
        
        <Anchors>
          <Anchor point="TOPLEFT" relativeKey="$parent.TitleArea" relativePoint="BOTTOMLEFT"/>
        </Anchors>
      <Scripts><OnLoad inherit="append">self.headingText = AUCTIONATOR_L_DEFAULT_TAB; </OnLoad></Scripts></Frame>

      <Frame inherits="AuctionatorDropDown" parentKey="DefaultTab">
       
         
         
         
       
       <Anchors>
         <Anchor point="TOPLEFT" relativeKey="$parent.DefaultTabHeading" relativePoint="BOTTOMLEFT"/>
       </Anchors>
      <Scripts><OnLoad inherit="append">self.labelText = AUCTIONATOR_L_DEFAULT_TAB_TEXT; self.textString = "NONE;SHOPPING_TAB;SELLING_TAB;CANCELLING_TAB;AUCTIONATOR"; self.valuesString = "0;1;2;3;4"; </OnLoad></Scripts></Frame>

      <Frame inherits="AuctionatorConfigurationHeadingFrame" parentKey="CraftingInfoHeading">
        
          
        
        <Anchors>
          <Anchor point="TOPLEFT" relativeKey="$parent.DefaultTab" relativePoint="BOTTOMLEFT"/>
        </Anchors>
      <Scripts><OnLoad inherit="append">self.headingText = AUCTIONATOR_L_CRAFTING_INFO; </OnLoad></Scripts></Frame>

      <Frame inherits="AuctionatorConfigurationCheckbox" parentKey="ShowCraftingInfo">
        
          
          
          
        
        <Anchors>
          <Anchor point="TOPLEFT" relativeKey="$parent.CraftingInfoHeading" relativePoint="BOTTOMLEFT" />
        </Anchors>
      <Scripts><OnLoad inherit="append">self.labelText = AUCTIONATOR_L_CONFIG_CRAFTING_INFO_SHOW; self.tooltipTitleText = AUCTIONATOR_L_CONFIG_CRAFTING_INFO_SHOW_TOOLTIP_HEADER; self.tooltipText = AUCTIONATOR_L_CONFIG_CRAFTING_INFO_SHOW_TOOLTIP_TEXT; </OnLoad></Scripts></Frame>

      <Frame inherits="AuctionatorConfigurationCheckbox" parentKey="ShowCraftingCost">
        
          
          
          
        
        <Anchors>
          <Anchor point="TOPLEFT" relativeKey="$parent.ShowCraftingInfo" relativePoint="BOTTOMLEFT" />
        </Anchors>
      <Scripts><OnLoad inherit="append">self.labelText = AUCTIONATOR_L_CONFIG_CRAFTING_INFO_SHOW_COST; self.tooltipTitleText = AUCTIONATOR_L_CONFIG_CRAFTING_INFO_SHOW_COST_TOOLTIP_HEADER; self.tooltipText = AUCTIONATOR_L_CONFIG_CRAFTING_INFO_SHOW_COST_TOOLTIP_TEXT; </OnLoad></Scripts></Frame>

      <Frame inherits="AuctionatorConfigurationCheckbox" parentKey="ShowCraftingProfit">
        
          
          
          
        
        <Anchors>
          <Anchor point="TOPLEFT" relativeKey="$parent.ShowCraftingCost" relativePoint="BOTTOMLEFT" />
        </Anchors>
      <Scripts><OnLoad inherit="append">self.labelText = AUCTIONATOR_L_CONFIG_CRAFTING_INFO_SHOW_PROFIT; self.tooltipTitleText = AUCTIONATOR_L_CONFIG_CRAFTING_INFO_SHOW_PROFIT_TOOLTIP_HEADER; self.tooltipText = AUCTIONATOR_L_CONFIG_CRAFTING_INFO_SHOW_PROFIT_TOOLTIP_TEXT; </OnLoad></Scripts></Frame>
   </Frames>
  </Frame>
</Ui>
