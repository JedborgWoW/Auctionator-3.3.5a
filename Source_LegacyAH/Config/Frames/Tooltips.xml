<Ui xmlns="http://www.blizzard.com/wow/ui/">
  <Frame
    name="AuctionatorConfigTooltipsFrameTemplate"
    virtual="true">

    <Scripts>
      <OnLoad>Mixin(self, AuctionatorConfigTooltipsFrameMixin); self:OnLoad()</OnLoad>
      <OnShow>self:OnShow()</OnShow>
      <OnHide>self:Save()</OnHide>
    </Scripts>

    <Frames>
      <Frame inherits="AuctionatorConfigurationTitleFrame" parentKey="TitleArea">
        
          
          
        
      <Scripts><OnLoad>self.titleText = AUCTIONATOR_L_CONFIG_TOOLTIPS_CATEGORY; self.subTitleText = AUCTIONATOR_L_CONFIG_TOOLTIPS_TEXT; </OnLoad></Scripts></Frame>

      <Frame inherits="AuctionatorConfigurationCheckbox" parentKey="AuctionTooltips">
        
          
        
        <Anchors>
          <Anchor point="TOPLEFT" relativeKey="$parent.TitleArea" relativePoint="BOTTOMLEFT"/>
        </Anchors>
      <Scripts><OnLoad>self.labelText = AUCTIONATOR_L_CONFIG_AUCTION_TOOLTIP; </OnLoad></Scripts></Frame>

      <Frame inherits="AuctionatorConfigurationCheckbox" parentKey="MailboxTooltips">
        
          
        
        <Anchors>
          <Anchor point="TOPLEFT" relativeKey="$parent.AuctionTooltips" relativePoint="BOTTOMLEFT"/>
        </Anchors>
      <Scripts><OnLoad>self.labelText = AUCTIONATOR_L_CONFIG_MAIL_TOOLTIP; </OnLoad></Scripts></Frame>

      <Frame inherits="AuctionatorConfigurationCheckbox" parentKey="VendorTooltips">
        
          
        
        <Anchors>
          <Anchor point="TOPLEFT" relativeKey="$parent.MailboxTooltips" relativePoint="BOTTOMLEFT"/>
        </Anchors>
      <Scripts><OnLoad>self.labelText = AUCTIONATOR_L_CONFIG_VENDOR_TOOLTIP; </OnLoad></Scripts></Frame>

      <Frame inherits="AuctionatorConfigurationCheckbox" parentKey="EnchantTooltips">
        
          
        
        <Anchors>
          <Anchor point="TOPLEFT" relativeKey="$parent.VendorTooltips" relativePoint="BOTTOMLEFT"/>
        </Anchors>
      <Scripts><OnLoad>self.labelText = AUCTIONATOR_L_CONFIG_ENCHANT_GENERIC_TOOLTIP; </OnLoad></Scripts></Frame>

      <Frame inherits="AuctionatorConfigurationCheckbox" parentKey="ProspectTooltips">
        
          
          
          
        
        <Anchors>
          <Anchor point="TOPLEFT" relativeKey="$parent.EnchantTooltips" relativePoint="BOTTOMLEFT"/>
        </Anchors>
      <Scripts><OnLoad>self.labelText = AUCTIONATOR_L_CONFIG_PROSPECT_TOOLTIP; self.tooltipTitleText = AUCTIONATOR_L_PROSPECT_TOOLTIP_TOOLTIP_HEADER; self.tooltipText = AUCTIONATOR_L_PROSPECT_TOOLTIP_TOOLTIP_TEXT; </OnLoad></Scripts></Frame>

      <Frame inherits="AuctionatorConfigurationCheckbox" parentKey="MillTooltips">
        
          
          
          
        
        <Anchors>
          <Anchor point="TOPLEFT" relativeKey="$parent.ProspectTooltips" relativePoint="BOTTOMLEFT"/>
        </Anchors>
      <Scripts><OnLoad>self.labelText = AUCTIONATOR_L_CONFIG_MILL_TOOLTIP; self.tooltipTitleText = AUCTIONATOR_L_MILL_TOOLTIP_TOOLTIP_HEADER; self.tooltipText = AUCTIONATOR_L_MILL_TOOLTIP_TOOLTIP_TEXT; </OnLoad></Scripts></Frame>

      <Frame inherits="AuctionatorConfigurationCheckbox" parentKey="AuctionAgeTooltips">
        
          
          
          
        
        <Anchors>
          <Anchor point="TOPLEFT" relativeKey="$parent.MillTooltips" relativePoint="BOTTOMLEFT"/>
        </Anchors>
      <Scripts><OnLoad>self.labelText = AUCTIONATOR_L_CONFIG_AUCTION_AGE_TOOLTIP; self.tooltipTitleText = AUCTIONATOR_L_AUCTION_AGE_TOOLTIP_TOOLTIP_HEADER; self.tooltipText = AUCTIONATOR_L_AUCTION_AGE_TOOLTIP_TOOLTIP_TEXT; </OnLoad></Scripts></Frame>

      <Frame inherits="AuctionatorConfigurationCheckbox" parentKey="ShiftStackTooltips">
        
          
          
          
        
        <Anchors>
          <Anchor point="TOPLEFT" relativeKey="$parent.AuctionAgeTooltips" relativePoint="BOTTOMLEFT"/>
        </Anchors>
      <Scripts><OnLoad>self.labelText = AUCTIONATOR_L_CONFIG_STACK_TOOLTIP; self.tooltipTitleText = AUCTIONATOR_L_STACK_TOOLTIP_TOOLTIP_HEADER; self.tooltipText = AUCTIONATOR_L_STACK_TOOLTIP_TOOLTIP_TEXT; </OnLoad></Scripts></Frame>
    </Frames>
  </Frame>
</Ui>
