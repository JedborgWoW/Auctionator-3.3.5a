<Ui>
  <Frame name="AuctionatorBuyFrameTemplate" virtual="true">
    <Size x="450" y="350" />
    <Frames>
      <Frame parentKey="CurrentPrices" setAllPoints="true" inherits="AuctionatorBuyCurrentPricesFrameTemplate"/>
      <Frame parentKey="HistoryPrices" setAllPoints="true" inherits="AuctionatorBuyHistoryPricesFrameTemplate" hidden="true"/>

      <Button inherits="UIPanelDynamicResizeButtonTemplate" text="AUCTIONATOR_L_HISTORY" parentKey="HistoryButton">
        <Anchors>
          <Anchor point="TOP" relativeKey="$parent.SearchResultsListing" relativePoint="BOTTOM"/>
          <Anchor point="LEFT" x="-8" y="10" />
        </Anchors>
        <Scripts>
          <OnClick>
            self:GetParent():ToggleHistory()
          </OnClick>
        <OnLoad>self.dynamicResizeMinWidth = 40; DynamicResizeButton_Resize(self)</OnLoad></Scripts>
      </Button>
    </Frames>
  <Scripts><OnLoad>Mixin(self, AuctionatorBuyFrameMixin); self.HistoryButton:SetPoint("TOP", self.SearchResultsListing, "BOTTOM")</OnLoad></Scripts></Frame>

  <Frame name="AuctionatorBuyFrameTemplateForShopping" hidden="true" inherits="AuctionatorBuyFrameTemplate" virtual="true">
    <Scripts>
      <OnLoad>Mixin(self, AuctionatorBuyFrameMixin); Mixin(self, AuctionatorBuyFrameMixinForShopping); self:Init(); self:SetPoint("TOPLEFT", self:GetParent().ResultsListing, "TOPLEFT", 0, -50); self.ReturnButton:ClearAllPoints(); if self.CurrentPrices and self.CurrentPrices.RefreshButton then self.ReturnButton:SetPoint("BOTTOMRIGHT", self.CurrentPrices.RefreshButton, "BOTTOMLEFT", -6, 0) else self.ReturnButton:SetPoint("BOTTOMLEFT", self.SearchResultsListing, "BOTTOMLEFT", 0, -2) end; self.HistoryButton:SetPoint("TOP", self.SearchResultsListing, "BOTTOM")</OnLoad>
      <OnShow>self:OnShow()</OnShow>
      <OnHide>self:OnHide()</OnHide>
    </Scripts>
    <Anchors>
      <Anchor point="TOPLEFT" relativeKey="$parent.ResultsListing" y="-50"/>
      <Anchor point="BOTTOMRIGHT"/>
    </Anchors>
    <Frames>
      <Button inherits="UIPanelDynamicResizeButtonTemplate" text="BACK" parentKey="ReturnButton">
        <Anchors>
          <Anchor point="BOTTOMLEFT" relativePoint="TOPLEFT" relativeKey="$parent.SearchResultsListing" y="10" />
        </Anchors>
        <Scripts>
          <OnClick>
            self:GetParent():Hide()
          </OnClick>
        <OnLoad>self.dynamicResizeMinWidth = 40; DynamicResizeButton_Resize(self)</OnLoad></Scripts>
      </Button>

      <Frame enableMouse="true">
        <Scripts>
          <OnLoad>Mixin(self, AuctionatorBuyingItemTooltipMixin); self:OnLoad(); self:SetSize(40, 40); local listing = self:GetParent().CurrentPrices and self:GetParent().CurrentPrices.SearchResultsListing; self:ClearAllPoints(); if listing and listing.HeaderContainer then self:SetPoint("BOTTOMLEFT", listing.HeaderContainer, "TOPLEFT", 20, 2) else self:SetPoint("LEFT", self:GetParent().ReturnButton, "RIGHT", 10, 0); self:SetPoint("TOP", 0, -9) end; self.Text:ClearAllPoints(); self.Text:SetPoint("LEFT", self.Icon, "RIGHT", 6, 0)</OnLoad>
          <OnEnter>self:OnEnter(motion)</OnEnter>
          <OnLeave>self:OnLeave(motion)</OnLeave>
          <OnMouseUp>self:OnMouseUp(button)</OnMouseUp>
        </Scripts>
        <Layers>
          <Layer>
            <Texture parentKey="Icon" setAllPoints="true">
              <Size x="40" y="40"/>
            </Texture>
            <FontString parentKey="Text" text="Item text" inherits="GameFontHighlight" justifyH="LEFT">
              <Size x="400" y="50"/>
              <Anchors>
                <Anchor point="LEFT" relativeKey="$parent.Icon" relativePoint="RIGHT" x="6"/>
              </Anchors>
            </FontString>
          </Layer>
        </Layers>
      </Frame>
    </Frames>
  </Frame>

  <Frame name="AuctionatorBuyFrameTemplateForSelling" inherits="AuctionatorBuyFrameTemplate" virtual="true">
    <Scripts>
      <OnShow>self:OnShow()</OnShow>
      <OnHide>self:OnHide()</OnHide>
      <OnEvent>self:OnEvent(event, ...)</OnEvent>
    <OnLoad>Mixin(self, AuctionatorBuyFrameMixin); Mixin(self, AuctionatorBuyFrameMixinForSelling); self.HistoryButton:SetPoint("TOP", self.SearchResultsListing, "BOTTOM")</OnLoad></Scripts>
  </Frame>
</Ui>
