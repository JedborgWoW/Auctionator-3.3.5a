<Ui xmlns="http://www.blizzard.com/wow/ui/">
  <Frame
    name="AuctionatorShoppingItemTemplate"
    inherits="ButtonFrameTemplate"
    frameStrata="Dialog"
    enableMouse="true"
    virtual="true"
    hidden="true"
  >
    <Size x="350" y="350" />

    <Scripts>
      <OnLoad>Mixin(self, ButtonFrameTemplateMixin); Mixin(self, AuctionatorShoppingItemMixin); self:OnLoad(); self:OnLoad(); self.SearchStringHeading:SetPoint("TOPLEFT", self.Inset, "TOPLEFT", 0, -5); self.SearchContainer:SetPoint("TOPLEFT", self.SearchStringHeading, "BOTTOMLEFT"); self.ItemClassHeading:SetPoint("TOPLEFT", self.SearchContainer, "BOTTOMLEFT"); self.FilterKeySelector:SetPoint("TOPLEFT", self.ItemClassHeading, "BOTTOMLEFT"); self.LevelRange:SetPoint("TOPLEFT", self.FilterKeySelector, "BOTTOMLEFT"); self.ItemLevelRange:SetPoint("TOPLEFT", self.LevelRange, "TOPRIGHT"); self.PriceRange:SetPoint("TOPLEFT", self.LevelRange, "BOTTOMLEFT", 0, -8); self.CraftedLevelRange:SetPoint("TOPLEFT", self.PriceRange, "TOPRIGHT"); self.PurchaseQuantity:SetPoint("TOPLEFT", self.PriceRange, "BOTTOMLEFT", 30, -22); self.QualityContainer:SetPoint("TOPLEFT", self.PurchaseQuantity, "BOTTOMLEFT", -4, 0); self.ExpansionContainer:SetPoint("TOPLEFT", self.QualityContainer, "BOTTOMLEFT", -6, -20); self.TierContainer:SetPoint("TOPLEFT", self.ExpansionContainer, "BOTTOMLEFT", 25, -20); self.Finished:SetPoint("TOPRIGHT", self.Inset, "BOTTOMRIGHT"); self.Cancel:SetPoint("TOPLEFT", self.Inset, "BOTTOMLEFT"); self.ResetAllButton:SetPoint("TOPLEFT", self.Cancel, "TOPRIGHT")</OnLoad>
      <OnShow>self:OnShow()</OnShow>
      <OnHide>self:OnHide()</OnHide>
      <OnKeyDown>self:OnKeyDown(key)</OnKeyDown>
      <OnKeyUp>self:OnKeyUp(key)</OnKeyUp>
    </Scripts>

    <Frames>
      <Frame inherits="AuctionatorConfigurationSubHeadingFrame" parentKey="SearchStringHeading">
        
          
        
        <Anchors>
          <Anchor point="TOPLEFT" relativeKey="$parent.Inset" relativePoint="TOPLEFT" y="-5" />
        </Anchors>
      <Scripts><OnLoad>Mixin(self, AuctionatorConfigurationSubHeadingMixin); self.subHeadingText = AUCTIONATOR_L_SEARCH_TERM; self:InitializeSubHeading()</OnLoad></Scripts></Frame>

      <Frame parentKey="SearchContainer"><Scripts><OnLoad>self.ResetSearchStringButton:SetPoint("TOPLEFT", self.SearchString, "TOPRIGHT", 3, -3); self.IsExact:SetPoint("TOPLEFT", self.SearchString, "BOTTOMLEFT", -8, 0)</OnLoad></Scripts>
        <Size y="48" />
        <Anchors>
          <Anchor point="TOPLEFT" relativeKey="$parent.SearchStringHeading" relativePoint="BOTTOMLEFT" />
          <Anchor point="RIGHT" />
        </Anchors>
        <Frames>
          <EditBox autoFocus="false" inherits="InputBoxTemplate" parentKey="SearchString" letters="100">
            <Size x="180" y="20"/>
            <Anchors>
              <Anchor point="TOPLEFT" relativeKey="$parent" relativePoint="TOPLEFT" x="24" y="-4" />
            </Anchors>
            <FontString inherits="ChatFontNormal" justifyH="LEFT"/>
            <Scripts>
              <OnEnterPressed>self:GetParent():GetParent():OnFinishedClicked()</OnEnterPressed>
              <OnEscapePressed>self:ClearFocus()</OnEscapePressed>
              <OnTabPressed>self:GetParent():GetParent().LevelRange:SetFocus()</OnTabPressed>
            <OnLoad></OnLoad></Scripts>
          </EditBox>

          <Button parentKey="ResetSearchStringButton" inherits="AuctionatorResetButton">
            <Anchors>
              <Anchor point="TOPLEFT" relativeKey="$parent.SearchString" relativePoint="TOPRIGHT" x="3" y="-3"/>
            </Anchors>
          <Scripts><OnLoad>Mixin(self, AuctionatorResetButtonMixin); self:OnLoad()</OnLoad></Scripts></Button>

          <CheckButton inherits="UICheckButtonTemplate" parentKey="IsExact">
            <Size x="20" y="20" />
            <Anchors>
              <Anchor point="TOPLEFT" relativeKey="$parent.SearchString"  relativePoint="BOTTOMLEFT" x="-8" />
            </Anchors>
            <Layers>
              <Layer level="BACKGROUND">
                <FontString inherits="GameFontHighlight" text="AUCTIONATOR_L_EXACT_SEARCH">
                  <Anchors>
                    <Anchor point="TOPLEFT" relativePoint="TOPLEFT" relativeKey="$parent" x="25" y="-4" />
                  </Anchors>
                </FontString>
              </Layer>
            </Layers>
          </CheckButton>
        </Frames>
      </Frame>

      <Frame inherits="AuctionatorConfigurationSubHeadingFrame" parentKey="ItemClassHeading">
        
          
        
        <Anchors>
          <Anchor point="TOPLEFT" relativeKey="$parent.SearchContainer" relativePoint="BOTTOMLEFT"/>
        </Anchors>
      <Scripts><OnLoad>Mixin(self, AuctionatorConfigurationSubHeadingMixin); self.subHeadingText = AUCTIONATOR_L_ITEM_CLASS; self:InitializeSubHeading()</OnLoad></Scripts></Frame>

      <Frame name="$parent_FilterKeySelector" parentKey="FilterKeySelector" inherits="AuctionatorFilterKeySelectorTemplate">
        <Anchors>
          <Anchor point="TOPLEFT" relativeKey="$parent.ItemClassHeading" relativePoint="BOTTOMLEFT"/>
        </Anchors>
      <Scripts><OnLoad>Mixin(self, AuctionatorFilterKeySelectorMixin); self:OnLoad()</OnLoad></Scripts></Frame>

      <Frame inherits="AuctionatorConfigurationMinMaxFrame" parentKey="LevelRange">
        
          
        
        <Anchors>
          <Anchor point="TOPLEFT" relativeKey="$parent.FilterKeySelector" relativePoint="BOTTOMLEFT"/>
        </Anchors>
      <Scripts><OnLoad>Mixin(self, AuctionatorConfigTooltipMixin); Mixin(self, AuctionatorConfigMinMaxMixin); self.titleText = AUCTIONATOR_L_LEVEL; self:OnLoad(); self:OnLoad(); self.MinBox:SetPoint("TOPLEFT", self.Title, "BOTTOMLEFT"); self.MaxBox:SetPoint("TOPLEFT", self.MinBox, "TOPRIGHT", 15, 0); self.ResetButton:SetPoint("TOPLEFT", self.MaxBox, "TOPRIGHT", 3, -3); self.Separator:SetPoint("CENTER", self.Title, "CENTER", -3, -19)</OnLoad></Scripts></Frame>

      <Frame inherits="AuctionatorConfigurationMinMaxFrame" parentKey="ItemLevelRange">
        
          
        
        <Anchors>
          <Anchor point="TOPLEFT" relativeKey="$parent.LevelRange" relativePoint="TOPRIGHT"/>
        </Anchors>
      <Scripts><OnLoad>Mixin(self, AuctionatorConfigTooltipMixin); Mixin(self, AuctionatorConfigMinMaxMixin); self.titleText = AUCTIONATOR_L_ITEM_LEVEL; self:OnLoad(); self:OnLoad(); self.MinBox:SetPoint("TOPLEFT", self.Title, "BOTTOMLEFT"); self.MaxBox:SetPoint("TOPLEFT", self.MinBox, "TOPRIGHT", 15, 0); self.ResetButton:SetPoint("TOPLEFT", self.MaxBox, "TOPRIGHT", 3, -3); self.Separator:SetPoint("CENTER", self.Title, "CENTER", -3, -19)</OnLoad></Scripts></Frame>

      <Frame inherits="AuctionatorConfigurationMinMaxFrame" parentKey="PriceRange">
        
          
        
        <Anchors>
          <Anchor point="TOPLEFT" relativeKey="$parent.LevelRange" relativePoint="BOTTOMLEFT" y="-8"/>
        </Anchors>
      <Scripts><OnLoad>Mixin(self, AuctionatorConfigTooltipMixin); Mixin(self, AuctionatorConfigMinMaxMixin); self.titleText = AUCTIONATOR_L_PRICE; self:OnLoad(); self:OnLoad(); self.MinBox:SetPoint("TOPLEFT", self.Title, "BOTTOMLEFT"); self.MaxBox:SetPoint("TOPLEFT", self.MinBox, "TOPRIGHT", 15, 0); self.ResetButton:SetPoint("TOPLEFT", self.MaxBox, "TOPRIGHT", 3, -3); self.Separator:SetPoint("CENTER", self.Title, "CENTER", -3, -19)</OnLoad></Scripts></Frame>

      <Frame inherits="AuctionatorConfigurationMinMaxFrame" parentKey="CraftedLevelRange">
        
          
        
        <Anchors>
          <Anchor point="TOPLEFT" relativeKey="$parent.PriceRange" relativePoint="TOPRIGHT"/>
        </Anchors>
      <Scripts><OnLoad>Mixin(self, AuctionatorConfigTooltipMixin); Mixin(self, AuctionatorConfigMinMaxMixin); self.titleText = AUCTIONATOR_L_CRAFTED_LEVEL; self:OnLoad(); self:OnLoad(); self.MinBox:SetPoint("TOPLEFT", self.Title, "BOTTOMLEFT"); self.MaxBox:SetPoint("TOPLEFT", self.MinBox, "TOPRIGHT", 15, 0); self.ResetButton:SetPoint("TOPLEFT", self.MaxBox, "TOPRIGHT", 3, -3); self.Separator:SetPoint("CENTER", self.Title, "CENTER", -3, -19)</OnLoad></Scripts></Frame>

      <Frame inherits="AuctionatorConfigurationNumericInputAlternate" parentKey="PurchaseQuantity">
        
          
        
        <Anchors>
          <Anchor point="TOPLEFT" relativeKey="$parent.PriceRange" relativePoint="BOTTOMLEFT" y="-22" x="30"/>
        </Anchors>
      <Scripts><OnLoad>Mixin(self, AuctionatorConfigTooltipMixin); Mixin(self, AuctionatorConfigNumericInputMixin); self.labelText = AUCTIONATOR_L_QUANTITY; self:OnLoad(); self:OnLoad()</OnLoad></Scripts></Frame>

      <Frame parentKey="QualityContainer"><Scripts><OnLoad>self.DropDown:SetPoint("TOPLEFT", self.Label, "TOPRIGHT", 0, 8); self.ResetQualityButton:SetPoint("TOPLEFT", self.DropDown.DropDown, "TOPRIGHT", 5, -5)</OnLoad></Scripts>
        <Size x="50" y="20"/>
        <Anchors>
          <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT" relativeKey="$parent.PurchaseQuantity" x="-4"/>
        </Anchors>
        <Layers>
          <Layer level="BACKGROUND">
            <FontString inherits="GameFontHighlight" parentKey="Label" text="RARITY">
              <Anchors>
                <Anchor point="TOPLEFT"/>
              </Anchors>
            </FontString>
          </Layer>
        </Layers>
        <Frames>
          <Frame inherits="AuctionatorDropDown" parentKey="DropDown">
            
              
            
            <Anchors>
              <Anchor point="TOPLEFT" relativeKey="$parent.Label" relativePoint="TOPRIGHT" y="8"/>
            </Anchors>
          <Scripts><OnLoad>Mixin(self, AuctionatorDropDownMixin); self.labelText = ""; self:OnLoad(); self.Label:SetPoint("LEFT", self.DropDown, "RIGHT", 15, 0)</OnLoad></Scripts></Frame>

          <Button parentKey="ResetQualityButton" inherits="AuctionatorResetButton">
            <Anchors>
              <Anchor point="TOPLEFT" relativeKey="$parent.DropDown.DropDown" relativePoint="TOPRIGHT" x="5" y="-5"/>
            </Anchors>
          <Scripts><OnLoad>Mixin(self, AuctionatorResetButtonMixin); self:OnLoad()</OnLoad></Scripts></Button>
        </Frames>
      </Frame>

      <Frame parentKey="ExpansionContainer"><Scripts><OnLoad>self.DropDown:SetPoint("TOPLEFT", self.Label, "TOPRIGHT", 0, 8); self.ResetExpansionButton:SetPoint("TOPLEFT", self.DropDown.DropDown, "TOPRIGHT", 5, -5)</OnLoad></Scripts>
        <Size x="50" y="20"/>
        <Anchors>
          <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT" relativeKey="$parent.QualityContainer" x="-6" y="-20" />
        </Anchors>
        <Layers>
          <Layer level="BACKGROUND">
            <FontString inherits="GameFontHighlight" parentKey="Label" text="AUCTIONATOR_L_EXPANSION">
              <Anchors>
                <Anchor point="TOPLEFT"/>
              </Anchors>
            </FontString>
          </Layer>
        </Layers>
        <Frames>
          <Frame inherits="AuctionatorDropDown" parentKey="DropDown">
            
              
            
            <Anchors>
              <Anchor point="TOPLEFT" relativeKey="$parent.Label" relativePoint="TOPRIGHT" y="8"/>
            </Anchors>
          <Scripts><OnLoad>Mixin(self, AuctionatorDropDownMixin); self.labelText = ""; self:OnLoad(); self.Label:SetPoint("LEFT", self.DropDown, "RIGHT", 15, 0)</OnLoad></Scripts></Frame>

          <Button parentKey="ResetExpansionButton" inherits="AuctionatorResetButton">
            <Anchors>
              <Anchor point="TOPLEFT" relativeKey="$parent.DropDown.DropDown" relativePoint="TOPRIGHT" x="5" y="-5"/>
            </Anchors>
          <Scripts><OnLoad>Mixin(self, AuctionatorResetButtonMixin); self:OnLoad()</OnLoad></Scripts></Button>
        </Frames>
      </Frame>

      <Frame parentKey="TierContainer"><Scripts><OnLoad>self.DropDown:SetPoint("TOPLEFT", self.Label, "TOPRIGHT", 0, 8); self.ResetTierButton:SetPoint("TOPLEFT", self.DropDown.DropDown, "TOPRIGHT", 5, -5)</OnLoad></Scripts>
        <Size x="50" y="20"/>
        <Anchors>
          <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT" relativeKey="$parent.ExpansionContainer" x="25" y="-20" />
        </Anchors>
        <Layers>
          <Layer level="BACKGROUND">
            <FontString inherits="GameFontHighlight" parentKey="Label" text="AUCTIONATOR_L_TIER">
              <Anchors>
                <Anchor point="TOPLEFT"/>
              </Anchors>
            </FontString>
          </Layer>
        </Layers>
        <Frames>
          <Frame inherits="AuctionatorDropDown" parentKey="DropDown">
            
              
            
            <Anchors>
              <Anchor point="TOPLEFT" relativeKey="$parent.Label" relativePoint="TOPRIGHT" y="8"/>
            </Anchors>
          <Scripts><OnLoad>Mixin(self, AuctionatorDropDownMixin); self.labelText = ""; self:OnLoad(); self.Label:SetPoint("LEFT", self.DropDown, "RIGHT", 15, 0)</OnLoad></Scripts></Frame>

          <Button parentKey="ResetTierButton" inherits="AuctionatorResetButton">
            <Anchors>
              <Anchor point="TOPLEFT" relativeKey="$parent.DropDown.DropDown" relativePoint="TOPRIGHT" x="5" y="-5"/>
            </Anchors>
          <Scripts><OnLoad>Mixin(self, AuctionatorResetButtonMixin); self:OnLoad()</OnLoad></Scripts></Button>
        </Frames>
      </Frame>

      <!-- Action Buttons -->
      <Button parentKey="Finished" inherits="UIPanelDynamicResizeButtonTemplate" text="">
        <Anchors>
          <Anchor point="TOPRIGHT" relativeKey="$parent.Inset" relativePoint="BOTTOMRIGHT" />
        </Anchors>

        <Scripts>
          <OnClick>self:GetParent():OnFinishedClicked()</OnClick>
        <OnLoad>self.dynamicResizeMinWidth = 40; DynamicResizeButton_Resize(self)</OnLoad></Scripts>
      </Button>

      <Button parentKey="Cancel" inherits="UIPanelDynamicResizeButtonTemplate" text="AUCTIONATOR_L_CANCEL">
        <Anchors>
          <Anchor point="TOPLEFT" relativeKey="$parent.Inset" relativePoint="BOTTOMLEFT"/>
        </Anchors>

        <Scripts>
          <OnClick>self:GetParent():OnCancelClicked()</OnClick>
        <OnLoad>self.dynamicResizeMinWidth = 40; DynamicResizeButton_Resize(self)</OnLoad></Scripts>
      </Button>

      <Button parentKey="ResetAllButton" inherits="UIPanelDynamicResizeButtonTemplate" text="AUCTIONATOR_L_RESET_ALL">
        <Anchors>
          <Anchor point="TOPLEFT" relativeKey="$parent.Cancel" relativePoint="TOPRIGHT"/>
        </Anchors>
        <Scripts>
          <OnClick>self:GetParent():ResetAll()</OnClick>
        <OnLoad>self.dynamicResizeMinWidth = 40; DynamicResizeButton_Resize(self)</OnLoad></Scripts>
      </Button>
    </Frames>
  </Frame>
</Ui>
