<Ui xmlns="http://www.blizzard.com/wow/ui/">
  <Button
    name="AuctionatorStringCellTemplate"
    inherits="AuctionatorCell"
    virtual="true"
  >
    <Layers>
      <Layer level="BACKGROUND">
        <FontString parentKey="text" inherits="GameFontHighlight" setAllPoints="true"/>
      </Layer>
    </Layers>
    <Scripts>
      <OnShow>self:OnShow()</OnShow>
      <OnHide>self:OnHide()</OnHide>
    <OnLoad inherit="append">Mixin(self, AuctionatorStringCellTemplateMixin); </OnLoad></Scripts>
  </Button>
</Ui>
