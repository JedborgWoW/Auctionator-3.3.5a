<Ui xmlns="http://www.blizzard.com/wow/ui/">
  <Button
    name="AuctionatorCell"
    parentKey="cell"
    enableMouse="true"
    virtual="true"
  >
    <Size y="16"/>

    <Scripts>
      <OnEnter>self:OnEnter(motion)</OnEnter>
      <OnLeave>self:OnLeave(motion)</OnLeave>
      <OnMouseUp>self:OnClick(button)</OnMouseUp>
    <OnLoad inherit="append">Mixin(self, AuctionatorCellMixin); </OnLoad></Scripts>
  </Button>
</Ui>
