<Ui xmlns="http://www.blizzard.com/wow/ui/">
  <Frame
    name="AuctionatorResultsRowTemplate"
    virtual="true"
    enableMouse="true"
  >
    <Size y="20"/>

    <Anchors>
      <Anchor point="LEFT"/>
      <Anchor point="RIGHT"/>
    </Anchors>

    <Layers>
      <Layer level="OVERLAY">
        <Texture parentKey="SelectedHighlight" file="Interface\QuestFrame\UI-QuestTitleHighlight" alphaMode="ADD" hidden="true">
          <Anchors>
            <Anchor point="TOPLEFT" relativePoint="TOPLEFT"/>
            <Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMRIGHT"/>
          </Anchors>
        </Texture>

        <!-- Using a normal texture for highlight to control the behavior. -->
        <Texture parentKey="HighlightTexture" file="Interface\QuestFrame\UI-QuestTitleHighlight" alphaMode="ADD" setAllPoints="true" hidden="true">
          <Anchors>
            <Anchor point="TOPLEFT" relativePoint="TOPLEFT"/>
            <Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMRIGHT"/>
          </Anchors>
        </Texture>

        <Texture parentKey="NormalTexture" atlas="auctionhouse-rowstripe-1" setAllPoints="true">
          <Anchors>
            <Anchor point="TOPLEFT" relativePoint="TOPLEFT"/>
            <Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMRIGHT"/>
          </Anchors>
        </Texture>
      </Layer>
    </Layers>

    <Scripts>
      <OnMouseUp>self:OnClick(button)</OnMouseUp>
      <OnEnter>self:OnEnter(motion)</OnEnter>
      <OnLeave>self:OnLeave(motion)</OnLeave>
    <OnLoad>Mixin(self, AuctionatorResultsRowTemplateMixin)</OnLoad></Scripts>
  </Frame>
</Ui>
