    name="AuctionatorResetButton"
    virtual="true"
    inherits="UIPanelButtonTemplate"
  >
    <Size x="15" y="15" />

    <Layers>
      <Layer level="ARTWORK">
        <Texture file="Interface\Buttons\UI-GroupLoot-Pass-Up" alpha="0.75" parentKey="texture"/>
      </Layer>
    </Layers>

    <Scripts>
      <OnLoad inherit="append">Mixin(self, AuctionatorResetButtonMixin); self:OnLoad()</OnLoad>
      <OnClick>self:OnClick(button, down)</OnClick>
    </Scripts>
  </Button>
</Ui>