<Ui>
  <Frame name="AuctionatorGroupsViewTemplate" virtual="true" parentKey="View">
    <Scripts>
      <OnLoad>Mixin(self, AuctionatorGroupsViewMixin); self.itemTemplate = "AuctionatorGroupsViewItemTemplate"; self.groupTemplate = "AuctionatorGroupsViewGroupTemplate"; self.groupInsetX = 0; self.clickEventName = "BagItemClicked"; self.completeEventName = "ViewComplete"; self.hideHiddenItems = false; self:OnLoad(); self.ScrollBox:SetPoint("BOTTOMRIGHT", self.ScrollBar, "BOTTOMLEFT", 0, 3)</OnLoad>
      <OnShow>self:OnShow()</OnShow>
      <OnHide>self:OnHide()</OnHide>
    </Scripts>
    
      
      
      
      
      
      
    
    <Frames>
      <Frame parentKey="ScrollBar" inherits="WowTrimScrollBar">
        <Anchors>
          <Anchor point="TOPRIGHT"/>
          <Anchor point="BOTTOMRIGHT"/>
        </Anchors>
      <Scripts><OnLoad>Mixin(self, ScrollBarMixin); self:OnLoad()</OnLoad></Scripts></Frame>
      <Frame inherits="WowScrollBox" parentKey="ScrollBox">
        <Anchors>
            <Anchor point="TOPLEFT"/>
            <Anchor point="BOTTOMRIGHT" relativeKey="$parent.ScrollBar" relativePoint="BOTTOMLEFT" y="3"/>
        </Anchors>
        <Frames>
          <Frame parentKey="ItemListingFrame">
            
              
            
          <Scripts><OnLoad>self.scrollable = true</OnLoad></Scripts></Frame>
        </Frames>
      <Scripts><OnLoad>Mixin(self, ScrollBoxMixin); self:OnLoad()</OnLoad></Scripts></Frame>
    </Frames>
  </Frame>
</Ui>
